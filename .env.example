# ── Required ──────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional fallback LLM ──────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Optional web search (DDG is free/keyless; Tavily is optional enrichment) ──
TAVILY_API_KEY=your_tavily_api_key_here

# ── Bot behavior ───────────────────────────────────────────────────────────────
DATABASE_PATH=data/bot.db
MAX_HISTORY_MESSAGES=20
MAX_FILE_SIZE_MB=10
TEMP_DIR=/tmp/discchatbot

# Channel IDs (comma-separated) where file uploads are auto-indexed.
# Leave empty to disable auto-indexing (users can still use /files upload).
FILE_UPLOAD_CHANNELS=

# ── LLM models ─────────────────────────────────────────────────────────────────
# Free tier models (no billing required), as of March 2026:
#   gemini-2.5-flash-lite  15 RPM, 1000 RPD — best for personal use
#   gemini-2.5-flash       10 RPM,  250 RPD — more capable
#   gemini-2.5-pro          5 RPM,  100 RPD — most capable, very limited
# NOTE: gemini-2.0-* models are deprecated and retiring March 2026
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Discord guild ID for instant slash command sync (your server's ID) ─────────
GUILD_ID=your_guild_id_here
